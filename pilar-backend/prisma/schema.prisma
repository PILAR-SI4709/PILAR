generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum StatusPendaftaran {
  PENDING
  APPROVED
  REJECTED
}

enum StatusEvent {
  UPCOMING
  ONGOING
  DONE
}

model User {
  id            String          @id @default(uuid())
  nama          String
  email         String          @unique
  password      String
  role          Role            @default(USER)
  foto          String?
  bio           String?
  noHp          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  pendaftaran   Pendaftaran[]
  dokumentasi   Dokumentasi[]
  sertifikat    Sertifikat[]
  eventDikelola Event[]

  @@map("users")
}

model Event {
  id          String      @id @default(uuid())
  judul       String
  deskripsi   String
  lokasi      String
  tanggal     DateTime
  kuota       Int
  gambar      String?
  status      StatusEvent @default(UPCOMING)
  adminId     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  admin         User          @relation(fields: [adminId], references: [id])
  pendaftaran   Pendaftaran[]
  dokumentasi   Dokumentasi[]
  sampah        Sampah[]
  sertifikat    Sertifikat[]

  @@map("events")
}

model Pendaftaran {
  id         String           @id @default(uuid())
  userId     String
  eventId    String
  status     StatusPendaftaran @default(PENDING)
  motivasi   String
  kesehatan  Json
  izin       Boolean          @default(false)
  nik        String
  alamat     String
  tanggalLahir DateTime
  noHp       String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  event       Event       @relation(fields: [eventId], references: [id])
  sertifikat  Sertifikat?

  @@unique([userId, eventId])
  @@map("pendaftaran")
}

model Dokumentasi {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  fotoUrl   String
  caption   String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("dokumentasi")
}

model Sampah {
  id        String   @id @default(uuid())
  eventId   String
  jenis     String
  jumlahKg  Float
  catatan   String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id])

  @@map("sampah")
}

model Sertifikat {
  id              String   @id @default(uuid())
  userId          String
  eventId         String
  pendaftaranId   String   @unique
  nomorSertifikat String   @unique
  issuedAt        DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id], onDelete: Cascade)
  event       Event       @relation(fields: [eventId], references: [id])
  pendaftaran Pendaftaran @relation(fields: [pendaftaranId], references: [id])

  @@map("sertifikat")
}